# Normalize line endings
* text=auto eol=lf
*.py text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Binary files — no EOL conversion
*.ico binary
*.png binary
*.jpg binary
*.wav binary
*.mp3 binary
*.onnx binary
*.dll binary
*.exe binary
